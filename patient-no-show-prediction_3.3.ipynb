    "# Binned previous no-show rate vs current no-show probability\n",
    "df['prev_rate_bin'] = pd.cut(\n",
    "    df['prev_no_show_rate'],\n",
    "    bins=[-0.01, 0, 0.2, 0.4, 0.6, 0.8, 1.01],\n",
    "    labels=['0%', '1–20%', '21–40%', '41–60%', '61–80%', '81–100%']\n",
