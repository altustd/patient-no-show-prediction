   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Load data"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Shape: (110527, 14)\n",
      "\n",
      "No-show rate:\n",
      "No-show\n",
      "No     0.7981\n",
      "Yes    0.2019\n",
      "Name: proportion, dtype: float64\n"
     ]
    }
   ],
   "source": [
    "df = pd.read_csv('KaggleV2-May-2016.csv', parse_dates=['ScheduledDay', 'AppointmentDay'])\n",
    "\n",
    "print('Shape:', df.shape)\n",
    "print('\\nNo-show rate:')\n",
    "print(df['No-show'].value_counts(normalize=True).round(4))"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Cleaning & feature engineering"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Cleaned shape: (110526, 24)\n"
     ]
    }
   ],
   "source": [
    "df = df.rename(columns={\n",
    "    'PatientId': 'patient_id', 'AppointmentID': 'appointment_id',\n",
    "    'Gender': 'gender', 'ScheduledDay': 'scheduled_day',\n",
    "    'AppointmentDay': 'appointment_day', 'Age': 'age',\n",
    "    'Neighbourhood': 'neighbourhood', 'Scholarship': 'scholarship',\n",
    "    'Hipertension': 'hypertension', 'Diabetes': 'diabetes',\n",
    "    'Alcoholism': 'alcoholism', 'Handcap': 'handicap',\n",
    "    'SMS_received': 'sms_received', 'No-show': 'no_show'\n",
    "})\n",
    "\n",
    "df['target'] = df['no_show'].map({'Yes': 1, 'No': 0})\n",
    "df = df.drop(columns=['no_show'])\n",
    "\n",
    "df['wait_days'] = (df['appointment_day'].dt.normalize() - df['scheduled_day'].dt.normalize()).dt.days.clip(lower=0)\n",
    "df['scheduled_hour'] = df['scheduled_day'].dt.hour\n",
    "df['appointment_dow'] = df['appointment_day'].dt.day_name()\n",
    "df['appointment_is_weekend'] = df['appointment_day'].dt.weekday >= 5\n",
    "df['same_day'] = (df['wait_days'] == 0).astype(int)\n",
    "\n",
    "df = df[(df['age'] >= 0) & (df['age'] <= 115)]\n",
    "df['handicap_binary'] = (df['handicap'] > 0).astype(int)\n",
    "\n",
    "# Patient history features\n",
    "df = df.sort_values(['patient_id', 'scheduled_day'])\n",
    "df['prev_appointments'] = df.groupby('patient_id').cumcount()\n",
    "df['cum_no_shows'] = df.groupby('patient_id')['target'].cumsum().shift(1).fillna(0)\n",
    "df['prev_no_show_rate'] = np.where(df['prev_appointments'] > 0, df['cum_no_shows'] / df['prev_appointments'], 0.0)\n",
    "df['days_since_last'] = df.groupby('patient_id')['appointment_day'].diff().dt.days.fillna(999)\n",
    "\n",
    "print('Cleaned shape:', df.shape)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Group rare neighbourhoods (prevents unseen category error)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Neighbourhoods after grouping: 77\n"
     ]
    }
   ],
   "source": [
    "rare_threshold = 50\n",
    "neigh_counts = df['neighbourhood'].value_counts()\n",
    "rare_neigh = neigh_counts[neigh_counts < rare_threshold].index\n",
    "df['neighbourhood'] = df['neighbourhood'].replace(rare_neigh, 'Other')\n",
    "\n",
    "print(\"Neighbourhoods after grouping:\", df['neighbourhood'].nunique())"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Train / test split"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "metadata": {},
   "outputs": [],
   "source": [
    "numeric_features = [\n",
    "    'age', 'wait_days', 'scheduled_hour', 'scholarship', 'hypertension',\n",
    "    'diabetes', 'alcoholism', 'handicap_binary', 'sms_received',\n",
    "    'prev_no_show_rate', 'days_since_last', 'same_day', 'appointment_is_weekend'\n",
    "]\n",
    "\n",
    "cat_features = ['gender', 'appointment_dow', 'neighbourhood']\n",
    "\n",
    "X = df[numeric_features + cat_features]\n",
    "y = df['target']\n",
    "\n",
    "X_train, X_test, y_train, y_test = train_test_split(\n",
    "    X, y, test_size=0.20, random_state=2025, stratify=y\n",
    ")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. Preprocessor & data transformation"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 6,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Transformed train dtypes:\n",
      " age                        float64\n",
      "wait_days                  float64\n",
      "scheduled_hour             float64\n",
      "scholarship                float64\n",
      "hypertension               float64\n",
      "diabetes                   float64\n",
      "alcoholism                 float64\n",
      "handicap_binary            float64\n",
      "sms_received               float64\n",
      "prev_no_show_rate          float64\n",
      "days_since_last            float64\n",
      "same_day                   float64\n",
      "appointment_is_weekend     float64\n",
      "gender                    category\n",
      "appointment_dow           category\n",
      "neighbourhood             category\n",
      "dtype: object\n"
     ]
    }
   ],
   "source": [
    "preprocessor = ColumnTransformer(\n",
    "    transformers=[\n",
    "        ('num', Pipeline([\n",
    "            ('impute', SimpleImputer(strategy='median')),\n",
    "            ('scale', StandardScaler())\n",
    "        ]), numeric_features),\n",
    "        ('cat', Pipeline([\n",
    "            ('impute', SimpleImputer(strategy='most_frequent')),\n",
    "            ('to_cat', FunctionTransformer(lambda x: x.astype('category')))\n",
    "        ]), cat_features)\n",
    "    ],\n",
    "    remainder='drop',\n",
    "    verbose_feature_names_out=False\n",
    ").set_output(transform=\"pandas\")\n",
    "\n",
    "X_train_tr = preprocessor.fit_transform(X_train)\n",
    "X_test_tr  = preprocessor.transform(X_test)\n",
    "\n",
    "print(\"Transformed train dtypes:\\n\", X_train_tr.dtypes)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 6. Training with DMatrix"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 7,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "[0]\ttrain-aucpr:0.39600\teval-aucpr:0.37614\n",
      "[100]\ttrain-aucpr:0.47072\teval-aucpr:0.42689\n",
      "[200]\ttrain-aucpr:0.50253\teval-aucpr:0.43347\n",
      "[300]\ttrain-aucpr:0.52932\teval-aucpr:0.43570\n",
      "[400]\ttrain-aucpr:0.55292\teval-aucpr:0.43592\n",
      "[441]\ttrain-aucpr:0.56169\teval-aucpr:0.43592\n",
      "\n",
      "Best iteration: 361\n"
     ]
    }
   ],
   "source": [
    "dtrain = xgb.DMatrix(\n",
    "    X_train_tr, label=y_train,\n",
    "    enable_categorical=True,\n",
    "    feature_names=X_train_tr.columns.tolist()\n",
    ")\n",
    "\n",
    "deval = xgb.DMatrix(\n",
    "    X_test_tr, label=y_test,\n",
    "    enable_categorical=True,\n",
    "    feature_names=X_train_tr.columns.tolist()\n",
    ")\n",
    "\n",
    "params = {\n",
    "    'objective': 'binary:logistic',\n",
    "    'eval_metric': 'aucpr',\n",
    "    'tree_method': 'hist',\n",
    "    'max_cat_threshold': 255,\n",
    "    'max_depth': 6,\n",
    "    'learning_rate': 0.035,\n",
    "    'subsample': 0.82,\n",
    "    'colsample_bytree': 0.78,\n",
    "    'scale_pos_weight': (y_train==0).sum() / (y_train==1).sum(),\n",
    "    'random_state': 2025\n",
    "}\n",
    "\n",
    "bst = xgb.train(\n",
    "    params,\n",
    "    dtrain,\n",
    "    num_boost_round=1200,\n",
    "    evals=[(dtrain, 'train'), (deval, 'eval')],\n",
    "    early_stopping_rounds=80,\n",
    "    verbose_eval=100\n",
    ")\n",
    "\n",
    "print(\"\\nBest iteration:\", bst.best_iteration)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 7. Evaluation"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 8,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "ROC AUC : 0.7625\n",
      "PR AUC  : 0.436\n",
      "\n",
      "Classification Report:\n",
      "               precision    recall  f1-score   support\n",
      "\n",
      "           0       0.91      0.62      0.74     17642\n",
      "           1       0.34      0.76      0.47      4464\n",
      "\n",
      "    accuracy                           0.65     22106\n",
      "   macro avg       0.62      0.69      0.60     22106\n",
      "weighted avg       0.80      0.65      0.68     22106\n",
      "\n"
     ]
    }
   ],
   "source": [
    "proba = bst.predict(deval)\n",
    "pred  = (proba >= 0.5).astype(int)\n",
    "\n",
    "print('ROC AUC :', round(roc_auc_score(y_test, proba), 4))\n",
    "print('PR AUC  :', round(average_precision_score(y_test, proba), 4))\n",
    "print('\\nClassification Report:\\n', classification_report(y_test, pred))"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
